{
  "name": "react-native-debounce-input-monorepo",
  "version": "2.0.0",
  "private": true,
  "description": "Monorepo for react-native-debounce-input and its development demo",
  "homepage": "https://github.com/yurkagon/react-native-debounce-input",
  "license": "MIT",
  "author": "Yurii Khvyshchuk <owngameplay@gmail.com>",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" build",
    "test": "pnpm --filter \"./packages/*\" test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "pnpm --filter demo dev",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
